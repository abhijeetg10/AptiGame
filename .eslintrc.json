{
    "env": {
        "browser": true,
        "es2021": true,
        "module": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-undef": "error",
        "no-console": "off"
    }
}
